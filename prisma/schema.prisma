/// TABLE 32: grading_criteria
/// ACTIVATION: Deploy when >3 branches need different grading or >20 courses exist.
/// Until then, application uses hardcoded defaults (5 metrics with fixed weights).
model GradingCriteria {
  id               String   @id @default(cuid())
  courseId          String   @map("course_id")
  metricNumber     Int      @map("metric_number")
  metricName       String   @map("metric_name") @db.VarChar(100)
  metricDescription String? @map("metric_description")
  weightPercentage Decimal  @map("weight_percentage") @db.Decimal(5, 2)
  displayOrder     Int      @map("display_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, metricNumber])
  @@index([courseId])
  @@map("grading_criteria")
}
